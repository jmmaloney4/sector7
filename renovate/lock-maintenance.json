{
	"$schema": "https://docs.renovatebot.com/renovate-schema.json",
	"description": "Lock file maintenance configuration",
	"addLabels": ["renovate"],
	"lockFileMaintenance": {
		"enabled": true,
		"schedule": ["before 4:00 am on Sunday"],
		"automerge": true,
		"packageRules": [{ "matchManagers": ["nix"], "allowedVersions": ">=0" }]
	}
}
